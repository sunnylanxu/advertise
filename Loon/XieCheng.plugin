[Rewrite]
# > 携程 - 获取服务器IP列表（可能关联更新或检测）
^https?:\/\/m\.ctrip\.com\/restapi\/soa2\/[0-9]{5}\/json\/getTimeZoneServerIpList\?__gw_os=IOS url reject

# > 携程 - 开屏广告
^https?:\/\/ma-adx\.ctrip\.com\/_ma\.gif url reject

# > 携程 - 8.47.0以上版本去广告（注：可能会导致部分图片不显示）
^https?:\/\/m\.ctrip\.com\/restapi\/soa2\/13916\/json\/tripAds url reject

# > 百度 - 落地页广告
^https?:\/\/mbd\.baidu\.com\/newspage\/api\/getmobads\?page\=landingshare url reject

[MITM]
hostname = m.ctrip.com, ma-adx.ctrip.com, mbd.baidu.com
